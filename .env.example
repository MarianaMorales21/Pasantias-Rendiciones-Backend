# Puerto del servidor (opcional, por defecto 8080)
PORT=8080

# Base de datos MySQL
DB_host=localhost
DB_user=root
DB_port=3306
DB_database=ren_fun
DB_password=tu_contraseña

# Correo SMTP (Gmail)
EMAIL="tu_correo@gmail.com"
EMAIL_PASSWORD="tu_app_password"

# URL del frontend (para CORS y enlaces de recuperación)
FRONTEND_URL=http://localhost:5173

# Ruta a los archivos estáticos del frontend (opcional, por defecto ../Pasantias-Frontend/dist)
# STATIC_DIR=/ruta/a/dist

# Secreto JWT
PALABRASECRETA=tu_secreto_jwt
